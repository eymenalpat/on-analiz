# /on-analiz skill credentials — copy to .env and fill values
# DO NOT commit .env to git

# DataForSEO — https://dataforseo.com (API credentials)
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=

# Google PageSpeed Insights — optional, only used in onboarding mode for CWV
# Get key at https://developers.google.com/speed/docs/insights/v5/get-started
PAGESPEED_API_KEY=

# Railway — optional, only used if you want auto-publish reports as public URLs
# Generate token at https://railway.app/account/tokens
RAILWAY_TOKEN=
RAILWAY_PROJECT_ID=

# Defaults
DEFAULT_LANG=tr
OUTPUT_DIR=./cikti
