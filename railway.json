{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "railway-workspace/Dockerfile"
  },
  "deploy": {
    "startCommand": "cd /app && python3 -m http.server ${PORT:-8080}",
    "healthcheckPath": "/",
    "restartPolicyType": "ON_FAILURE"
  }
}
